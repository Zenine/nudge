include README.md
include LICENSE
include CHANGELOG.md
include pyproject.toml
recursive-include nudge/apple *.swift
recursive-include nudge/skills/builtins *.yaml
include docs/*.md
recursive-include examples *.md *.json *.yaml
prune tests
prune .nudge
prune dist
prune build
global-exclude *.py[cod] __pycache__/* .DS_Store *.db *.sqlite *.sqlite3 *.zip config.toml .env
